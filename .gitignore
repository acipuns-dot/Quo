# Ignore everything by default.
*

# Keep the ignore file itself.
!.gitignore

# Keep the web app source.
!app/
!app/**
!components/
!components/**
!hooks/
!hooks/**
!lib/
!lib/**
!types/
!types/**
!public/
!public/**

# Keep web project config and package metadata.
!package.json
!package-lock.json
!next-env.d.ts
!next.config.ts
!tailwind.config.ts
!postcss.config.js
!tsconfig.json
!eslint.config.mjs
